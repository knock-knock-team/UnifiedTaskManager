# Copy to .env for local non-secret defaults.
# Do not commit real secrets.

# user-service HTTP
HTTP_ADDR=:8082
CORS_ALLOW_ORIGIN=*
ENV=local
LOG_LEVEL=info
SLOW_REQUEST_MS=750
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# postgres
POSTGRES_DB=unified_task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

# rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change-me-rabbit-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# user-service storage
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
USE_IN_MEMORY=false
AUTO_MIGRATE=true

# auth
JWT_SECRET=change-me-jwt-secret
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_HOURS=168

# bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@local.dev
BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-password
BOOTSTRAP_ADMIN_NAME=System Admin

# Board realtime (task-service); uses redis from docker-compose.local.yml
TASK_BOARD_REDIS_URL=redis://localhost:6379/0

# RabbitMQ domain events
RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@localhost:${RABBITMQ_PORT}/
RABBITMQ_EXCHANGE=user.events

# outbox maintenance
OUTBOX_CLEANER_ENABLED=true
OUTBOX_ARCHIVE_ENABLED=true
OUTBOX_RETENTION_DAYS=7
OUTBOX_CLEANUP_INTERVAL_SECONDS=60
OUTBOX_CLEANUP_BATCH_SIZE=500
OUTBOX_MAX_ATTEMPTS=10

# operational admin endpoints protection
ADMIN_OPS_TOKEN=change-me-ops-token

# integration test DB
INTEGRATION_DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# file-service
FILE_SERVICE_HTTP_ADDR=:8088
FILE_SERVICE_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
FILE_SERVICE_STORAGE_ROOT=./services/file-service/storage
FILE_SERVICE_RABBITMQ_ENABLED=true
FILE_SERVICE_RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@localhost:${RABBITMQ_PORT}/
FILE_SERVICE_USER_SERVICE_URL=http://localhost:8082
FILE_SERVICE_USER_EXISTS_QUEUE=user-service.user-exists
FILE_SERVICE_DELETED_FILE_QUEUE=task-service.file-deleted
FILE_SERVICE_AGENT_COMMANDS_QUEUE=file-service.agent-commands
FILE_SERVICE_RPC_TIMEOUT_SECONDS=3

# task-service
TASK_SERVICE_AGENT_COMMANDS_QUEUE=task-service.agent-commands

# ml-service task/file agent
ML_SERVICE_RABBITMQ_ENABLED=true
ML_SERVICE_RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@localhost:${RABBITMQ_PORT}/
TASK_FILE_AGENT_GATEWAY_BASE_URL=http://localhost:8080


SBER_AUTH=
LOGGER_LEVEL=DEBUG

# email delivery for registration codes and notification-service / Yandex SMTP
NOTIFICATION_SERVICE_HTTP_ADDR=:8089
NOTIFICATION_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
NOTIFICATION_USER_SERVICE_URL=http://localhost:8082
NOTIFICATION_AUTO_MIGRATE=true
NOTIFICATION_AUTO_SEND_ENABLED=true
NOTIFICATION_DEADLINE_LOOKAHEAD_MINUTES=1440
NOTIFICATION_DEFAULT_URGENT_BEFORE_MINUTES=120
NOTIFICATION_SCAN_INTERVAL_SECONDS=300
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=UnifiedTaskManager
PUBLIC_FRONTEND_URL=http://localhost:8080
