# Production Environment Variables (copy and customize)

# Docker image tag/version
IMAGE_TAG=v0.1.3

# PostgreSQL
POSTGRES_DB=unified_task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-strong-password

# RabbitMQ  
RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=change-me-to-strong-password

# JWT & CORS
JWT_SECRET=change-me-to-secure-random-string
CORS_ALLOW_ORIGIN=https://your-domain.com

# Service URLs (internal Docker network)
GATEWAY_HTTP_ADDR=:8081
GATEWAY_USER_SERVICE_URL=http://user-service:8082
GATEWAY_TASK_SERVICE_URL=http://task-service:8083
GATEWAY_CHAT_SERVICE_URL=http://chat-service:8084
GATEWAY_CALL_SERVICE_URL=http://sfu-service:8086
GATEWAY_FILE_SERVICE_URL=http://file-service:8088

# File Service
FILE_SERVICE_HTTP_ADDR=:8088
FILE_SERVICE_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
FILE_SERVICE_STORAGE_ROOT=/var/lib/file-service/storage
FILE_SERVICE_RABBITMQ_ENABLED=true
FILE_SERVICE_RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/
FILE_SERVICE_USER_EXISTS_QUEUE=user-service.user-exists
FILE_SERVICE_DELETED_FILE_QUEUE=task-service.file-deleted
FILE_SERVICE_RPC_TIMEOUT_SECONDS=3
