# Production Environment Variables (copy and customize)

# Docker image tag/version
IMAGE_TAG=v0.1.3

# PostgreSQL
POSTGRES_DB=unified_task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-strong-password

# RabbitMQ  
RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=change-me-to-strong-password

# JWT & CORS
JWT_SECRET=change-me-to-secure-random-string
CORS_ALLOW_ORIGIN=https://your-domain.com
ENV=production
LOG_LEVEL=info
SLOW_REQUEST_MS=750
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-to-strong-password

# Service URLs (internal Docker network)
GATEWAY_HTTP_ADDR=:8081
GATEWAY_USER_SERVICE_URL=http://user-service:8082
GATEWAY_TASK_SERVICE_URL=http://task-service:8083
GATEWAY_CHAT_SERVICE_URL=http://chat-service:8084
GATEWAY_CALL_SERVICE_URL=http://sfu-service:8086
GATEWAY_FILE_SERVICE_URL=http://file-service:8088
GATEWAY_NOTIFICATION_SERVICE_URL=http://notification-service:8089

# File Service
FILE_SERVICE_HTTP_ADDR=:8088
FILE_SERVICE_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
FILE_SERVICE_STORAGE_ROOT=/var/lib/unified-task-manager-file-service/storage
FILE_SERVICE_RABBITMQ_ENABLED=true
FILE_SERVICE_RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672/
FILE_SERVICE_USER_SERVICE_URL=http://user-service:8082
FILE_SERVICE_USER_EXISTS_QUEUE=user-service.user-exists
FILE_SERVICE_DELETED_FILE_QUEUE=task-service.file-deleted
FILE_SERVICE_RPC_TIMEOUT_SECONDS=3

# Email delivery for registration codes and Notification Service / Yandex SMTP
NOTIFICATION_SERVICE_HTTP_ADDR=:8089
NOTIFICATION_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
NOTIFICATION_USER_SERVICE_URL=http://user-service:8082
NOTIFICATION_AUTO_MIGRATE=true
NOTIFICATION_AUTO_SEND_ENABLED=true
NOTIFICATION_DEADLINE_LOOKAHEAD_MINUTES=1440
NOTIFICATION_DEFAULT_URGENT_BEFORE_MINUTES=120
NOTIFICATION_SCAN_INTERVAL_SECONDS=300
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=your-yandex-login@yandex.ru
SMTP_PASSWORD=your-yandex-app-password
SMTP_FROM=your-yandex-login@yandex.ru
SMTP_FROM_NAME=UnifiedTaskManager
PUBLIC_FRONTEND_URL=https://your-domain.com
